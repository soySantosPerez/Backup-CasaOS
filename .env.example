# === HOST IDENTITY ===
# A short name for this machine (used in backup filenames and Telegram messages)
HOST_NAME=my-pi

# === BACKUP DESTINATION ===
# Path to the NAS or external storage mount on this host
BACKUP_DEST=/mnt/nas/backups

# Number of backups to keep per host (oldest are deleted)
BACKUP_RETENTION=3

# === PATHS TO BACK UP ===
# Comma-separated list of directories to include in the tar.gz
PATHS_TO_BACKUP=/DATA,/var/lib/casaos

# === POSTGRES DATABASES (optional) ===
# If any of your CasaOS apps use Postgres, list them here.
# Format: container_name:pg_user:db_name (comma-separated for multiple)
# Leave empty if you don't use Postgres.
PG_DUMP_DBS=

# === TELEGRAM NOTIFICATIONS ===
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
